# Username and password for Basic Auth (only used if authentication_method: basic_auth)
FHIR_USER="your_username"
FHIR_PASSWORD="your_password"

# Base URL of the FHIR server
# Example: "https://your-server.example.org/app/FHIR/r4/"
FHIR_SERVER_URL="https://your-fhir-base-url/"

# VERIFY_SSL_ENV="true" (default if left empty)
# VERIFY_SSL_ENV="false"

# Base URL of the FHIR server (used in token mode)
# Example: "https://your-server.example.org/app/FHIR/r4/"
SEARCH_URL="https://your-fhir-base-url/"

# Auth endpoint for token-based authentication
# Example: "https://your-server.example.org:8443/app/Auth/v1/basicAuth"
BASIC_AUTH="https://your-auth-endpoint/basicAuth"

# Refresh endpoint for token-based authentication
# Example: "https://your-server.example.org:8443/app/Auth/v1/refreshToken"
REFRESH_AUTH="https://your-auth-endpoint/refreshToken"

